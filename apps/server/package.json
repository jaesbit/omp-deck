{
	"name": "@omp-deck/server",
	"version": "0.6.1",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"scripts": {
		"dev": "bun --hot src/index.ts",
		"start": "bun src/index.ts",
		"start:prod": "bun dist/index.js",
		"build": "rm -rf dist && bun build src/index.ts --target=bun --outdir=dist --minify --external mupdf --external '@oh-my-pi/*' && cp -R src/db/migrations dist/migrations && cp -R src/templates dist/templates",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@oh-my-pi/pi-ai": "16.3.11",
		"@oh-my-pi/pi-coding-agent": "16.3.11",
		"@omp-deck/protocol": "workspace:*",
		"croner": "^10.0.1",
		"hono": "^4.12.27",
		"quickjs-emscripten": "^0.32.0",
		"yaml": "^2.9.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"typescript": "^6.0.3"
	},
	"engines": {
		"bun": ">=1.3.14"
	}
}
