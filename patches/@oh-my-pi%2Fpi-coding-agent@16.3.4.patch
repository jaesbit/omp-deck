diff --git a/node_modules/@oh-my-pi/pi-coding-agent/src/irc/bus.test.ts b/src/irc/bus.test.ts
new file mode 100755
index 0000000000000000000000000000000000000000..068b44413a8e35a1829efdf68c05e0be4424ba1c
--- /dev/null
+++ b/src/irc/bus.test.ts
@@ -0,0 +1,83 @@
+import { describe, expect, it, mock } from "bun:test";
+import type { AgentRegistry } from "../registry/agent-registry";
+import type { AgentSession } from "../session/agent-session";
+
+interface IrcMessage {
+	id: string;
+	from: string;
+	to: string;
+	body: string;
+	ts: number;
+	replyTo?: string;
+}
+
+mock.module("@oh-my-pi/pi-utils", () => ({
+	logger: { debug: () => {} },
+	Snowflake: { next: () => "test-message" },
+	oneLineLabel: (value: string) => value,
+}));
+mock.module("../task/types", () => ({ oneLineLabel: (value: string) => value }));
+
+// Load after the test-local utility mock because this installed dependency omits @oh-my-pi/pi-utils.
+const { AgentRegistry, MAIN_AGENT_ID } = await import("../registry/agent-registry");
+const { IrcBus } = await import("./bus");
+
+function recordingSession(received: IrcMessage[]): AgentSession {
+	return {
+		async deliverIrcMessage(message: IrcMessage): Promise<"injected"> {
+			received.push(message);
+			return "injected";
+		},
+	} as unknown as AgentSession;
+}
+
+function registerScope(registry: AgentRegistry, mainMessages: IrcMessage[], workerMessages: IrcMessage[]): void {
+	registry.register({
+		id: MAIN_AGENT_ID,
+		displayName: MAIN_AGENT_ID,
+		kind: "main",
+		status: "idle",
+		session: recordingSession(mainMessages),
+	});
+	registry.register({
+		id: "Worker",
+		displayName: "Worker",
+		kind: "sub",
+		status: "idle",
+		session: recordingSession(workerMessages),
+	});
+}
+
+describe("IrcBus.forRegistry", () => {
+	it("delivers identically named peers only within their own registry", async () => {
+		const registryA = new AgentRegistry();
+		const registryB = new AgentRegistry();
+		const mainA: IrcMessage[] = [];
+		const workerA: IrcMessage[] = [];
+		const mainB: IrcMessage[] = [];
+		const workerB: IrcMessage[] = [];
+		registerScope(registryA, mainA, workerA);
+		registerScope(registryB, mainB, workerB);
+
+		const busA = IrcBus.forRegistry(registryA);
+		expect(await busA.send({ from: "Worker", to: MAIN_AGENT_ID, body: "worker-to-main" })).toEqual({
+			to: MAIN_AGENT_ID,
+			outcome: "injected",
+		});
+		expect(mainA).toHaveLength(1);
+		expect(mainA[0]).toMatchObject({ from: "Worker", to: MAIN_AGENT_ID, body: "worker-to-main" });
+		expect(workerA).toEqual([]);
+		expect(mainB).toEqual([]);
+		expect(workerB).toEqual([]);
+
+		expect(await busA.send({ from: MAIN_AGENT_ID, to: "Worker", body: "main-to-worker" })).toEqual({
+			to: "Worker",
+			outcome: "injected",
+		});
+		expect(workerA).toHaveLength(1);
+		expect(workerA[0]).toMatchObject({ from: MAIN_AGENT_ID, to: "Worker", body: "main-to-worker" });
+		expect(mainA).toHaveLength(1);
+		expect(mainB).toEqual([]);
+		expect(workerB).toEqual([]);
+	});
+});
