{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omp-deck.app/schemas/trigger-event.json",
  "title": "RoutineTrigger — event",
  "description": "Event-source trigger. V1 sources: telegram, deck_inbox, deck_task, routine_finished. MCP-notification sources land in V2.",
  "type": "object",
  "required": ["event"],
  "properties": {
    "event": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1,
          "description": "Event source id."
        },
        "type": {
          "type": "string",
          "description": "Source-specific event subtype. e.g. for 'gmail': 'new_message'."
        },
        "filter": {
          "type": "string",
          "description": "JS boolean expression evaluated in the sandbox against the event payload; trigger fires only if it returns truthy."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
