{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://omp-deck.app/schemas/step-deck.json",
  "title": "RoutineStep — deck",
  "description": "First-party omp-deck action. Safer than generic HTTP for deck-owned mutations like creating inbox items or tasks.",
  "type": "object",
  "allOf": [
    { "$ref": "https://omp-deck.app/schemas/step-common.json" },
    {
      "type": "object",
      "required": ["type", "action"],
      "properties": {
        "type": { "const": "deck" },
        "action": {
          "enum": [
            "create_inbox_item",
            "create_task",
            "move_task",
            "promote_inbox_item_to_task"
          ]
        }
      },
      "oneOf": [
        {
          "required": ["action", "kind", "title"],
          "properties": {
            "action": { "const": "create_inbox_item" },
            "kind": {
              "enum": ["email", "ticket", "idea", "decision", "investigation", "capture"]
            },
            "title": { "type": "string", "minLength": 1, "maxLength": 500 },
            "body": { "type": "string" },
            "source": { "type": "string", "minLength": 1, "maxLength": 200 }
          }
        },
        {
          "required": ["action", "title"],
          "properties": {
            "action": { "const": "create_task" },
            "title": { "type": "string", "minLength": 1, "maxLength": 500 },
            "body": { "type": "string" },
            "state_ref": { "type": "string", "minLength": 1, "maxLength": 120 },
            "cwd": { "type": "string", "minLength": 1, "maxLength": 1000 }
          }
        },
        {
          "required": ["action", "task_ref", "state_ref"],
          "properties": {
            "action": { "const": "move_task" },
            "task_ref": { "type": "string", "minLength": 1, "maxLength": 120 },
            "state_ref": { "type": "string", "minLength": 1, "maxLength": 120 },
            "index": { "type": "integer", "minimum": 0, "default": 0 }
          }
        },
        {
          "required": ["action", "inbox_ref"],
          "properties": {
            "action": { "const": "promote_inbox_item_to_task" },
            "inbox_ref": { "type": "string", "minLength": 1, "maxLength": 120 },
            "state_ref": { "type": "string", "minLength": 1, "maxLength": 120 },
            "mark_processed": { "type": "boolean", "default": true }
          }
        }
      ]
    }
  ]
}
